  "Provide configuration using Koanf": {
    "prefix": "config_with_koanf",
    "body": [
      "package config",
      "",
      "import (",
      "\t\"encoding/json\"",
      "\t\"log\"",
      "\t\"strings\"",
      "",
      "\t\"github.com/knadh/koanf/parsers/toml\"",
      "\t\"github.com/knadh/koanf/providers/env\"",
      "\t\"github.com/knadh/koanf/providers/file\"",
      "\t\"github.com/knadh/koanf/providers/structs\"",
      "\t\"github.com/knadh/koanf/v2\"",
      "\t\"github.com/tidwall/pretty\"",
      ")",
      "",
      "// prefix indicates environment variables prefix.",
      "const prefix = \"${1:APP}_\"",
      "",
      "// Config holds all configurations.",
      "type Config struct {",
      "}",
      "",
      "func Provide() Config {",
      "\tk := koanf.New(\".\")",
      "",
      "\t// load default configuration from default function",
      "\tif err := k.Load(structs.Provider(Default(), \"koanf\"), nil); err != nil {",
      "\t\tlog.Fatalf(\"error loading default: %s\", err)",
      "\t}",
      "",
      "\t// load configuration from file",
      "\tif err := k.Load(file.Provider(\"config.toml\"), toml.Parser()); err != nil {",
      "\t\tlog.Printf(\"error loading config.toml: %s\", err)",
      "\t}",
      "",
      "\t// load environment variables",
      "\tif err := k.Load(",
      "\t\t// replace __ with . in environment variables so you can reference field a in struct b",
      "\t\t// as a__b.",
      "\t\tenv.Provider(prefix, \".\", func(source string) string {",
      "\t\t\tbase := strings.ToLower(strings.TrimPrefix(source, prefix))",
      "",
      "\t\t\treturn strings.ReplaceAll(base, \"__\", \".\")",
      "\t\t}),",
      "\t\tnil,",
      "\t); err != nil {",
      "\t\tlog.Printf(\"error loading environment variables: %s\", err)",
      "\t}",
      "",
      "\tvar instance Config",
      "\tif err := k.Unmarshal(\"\", &instance); err != nil {",
      "\t\tlog.Fatalf(\"error unmarshalling config: %s\", err)",
      "\t}",
      "",
      "\tindent, err := json.MarshalIndent(instance, \"\", \"\\t\")",
      "\tif err != nil {",
      "\t\tpanic(err)",
      "\t}",
      "",
      "\tindent = pretty.Color(indent, nil)",
      "",
      "\tlog.Printf(`",
      "================ Loaded Configuration ================",
      "%s",
      "======================================================",
      "\t`, string(indent))",
      "",
      "\treturn instance",
      "}"
    ],
    "description": "Write down the code for loading configuration using koanf from default, TOML file and env"
  }
}
